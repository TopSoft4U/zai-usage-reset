{
  "manifest_version": 3,
  "name": "z.ai Quota Reset Timer",
  "version": "1.2.0",
  "description": "Shows quota reset times in local time on z.ai subscription page",
  "homepage_url": "https://github.com/TopSoft4U/zai-usage-reset",
  "author": "TopSoft4U",
  "icons": {
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": [],
  "host_permissions": ["https://api.z.ai/*"],
  "content_scripts": [
    {
      "matches": ["https://z.ai/manage-apikey/subscription*"],
      "js": ["injector.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://z.ai/manage-apikey/subscription*"],
      "js": ["content.js"],
      "world": "MAIN",
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["content.js"],
      "matches": ["https://z.ai/*"]
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "zai-quota-reset@topsoft4u.com",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}
